<UserControl x:Class="ReringProject.Custom.UI.BottomVisionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280"
             d:DesignHeight="900">
    <!--260624 hbk Phase 61: Bottom 비전 뷰 (AV-08) — 좌측 컨트롤 패널 + 우측 뷰어 호스트 (airspace-safe)-->
    <!--Tray 와 동일한 2-컬럼 구조. Bottom 추가: Theta 결과 + 피커센터 캘 패널-->
    <UserControl.Resources>
        <Style x:Key="BottomActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E3A8A"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#172554"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#CBD5E1"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#CBD5E1"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!--루트 Grid: 좌측 컬럼(컨트롤 패널) + 우측 컬럼(뷰어 호스트). airspace-safe — 두 컬럼은 완전히 분리된 Grid 셀-->
    <Grid Background="#E2E8F0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--좌측 컬럼: 컨트롤 패널 (네이티브 HWND 밖 — WPF 오버레이 가능)-->
        <Border Grid.Column="0" Margin="12" Padding="12" Background="#F8FAFC" CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!--Row 0: 헤더-->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Bottom 비전"/>
                        <TextBlock Margin="0,4,0,0" Foreground="#475569" Text="Grab / 티칭 / Shape 검사 / 피커센터 캘"/>
                    </StackPanel>

                    <!--Row 1: 상태 라벨 (연결/대기 상태)-->
                    <Border Grid.Row="1" Margin="0,0,0,10" Padding="8,6" Background="#F1F5F9" CornerRadius="4">
                        <TextBlock x:Name="lbl_status" Text="대기" FontSize="13" Foreground="#334155"/>
                    </Border>

                    <!--Row 2: 툴바 (Grab/Live/Stop + 오프라인 이미지 로더)-->
                    <GroupBox Grid.Row="2" Header="카메라 / 이미지 로더" Margin="0,0,0,8">
                        <StackPanel Margin="8">
                            <WrapPanel>
                                <Button x:Name="btn_grab"
                                        Content="Grab"
                                        Style="{StaticResource BottomActionButtonStyle}"
                                        Click="GrabButton_Click"/>
                                <Button x:Name="btn_live"
                                        Content="Live"
                                        Style="{StaticResource BottomActionButtonStyle}"
                                        Click="LiveButton_Click"/>
                                <Button x:Name="btn_stop"
                                        Content="Stop"
                                        Style="{StaticResource BottomActionButtonStyle}"
                                        Click="StopButton_Click"/>
                                <!--260625 hbk Phase 61.1 오프라인 이미지 로더-->
                                <Button x:Name="btn_openFolder" Content="폴더 열기"
                                        Style="{StaticResource BottomActionButtonStyle}" Click="OpenFolderButton_Click"/>
                                <Button x:Name="btn_prevImage" Content="◀ 이전"
                                        Style="{StaticResource BottomActionButtonStyle}" Click="PrevImageButton_Click"/>
                                <Button x:Name="btn_nextImage" Content="다음 ▶"
                                        Style="{StaticResource BottomActionButtonStyle}" Click="NextImageButton_Click"/>
                            </WrapPanel>
                            <TextBlock x:Name="lbl_loaderStatus" Margin="8,0,0,4" FontSize="12"
                                       Foreground="#475569" Text="로드된 이미지 없음" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <!--Row 3: 티칭 패널 (ROI 2개 그리기 + 티칭 저장)-->
                    <GroupBox Grid.Row="3" Header="티칭 (ROI 2개)" Margin="0,0,0,8">
                        <StackPanel Margin="8">
                            <WrapPanel Margin="0,0,0,6">
                                <Button x:Name="btn_drawRoi1"
                                        Content="ROI 1 그리기"
                                        Style="{StaticResource BottomActionButtonStyle}"
                                        Click="DrawRoi1Button_Click"/>
                                <Button x:Name="btn_drawRoi2"
                                        Content="ROI 2 그리기"
                                        Style="{StaticResource BottomActionButtonStyle}"
                                        Click="DrawRoi2Button_Click"/>
                            </WrapPanel>
                            <Button x:Name="btn_teach"
                                    Content="티칭 저장"
                                    Style="{StaticResource BottomActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Click="TeachButton_Click"/>
                            <TextBlock x:Name="lbl_teachStatus"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="#475569"
                                       Text="티칭 없음"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <!--Row 4: 검사 결과 패널 (Bottom: X/Y Offset + Theta + Score)-->
                    <GroupBox Grid.Row="4" Header="검사 결과" Margin="0,0,0,8">
                        <StackPanel Margin="8">
                            <Button x:Name="btn_run"
                                    Content="검사"
                                    Style="{StaticResource BottomActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Click="RunButton_Click"/>
                            <!--260625 hbk Phase 61.1 시각화 토글 (airspace-safe: 좌측 패널)-->
                            <CheckBox x:Name="chk_showRoi" Content="ROI 표시" IsChecked="True" Margin="0,8,0,0"
                                      Checked="ShowRoiCheckBox_Changed" Unchecked="ShowRoiCheckBox_Changed"/>
                            <CheckBox x:Name="chk_showEdge" Content="에지 표시" IsChecked="True" Margin="0,4,0,0"
                                      Checked="ShowEdgeCheckBox_Changed" Unchecked="ShowEdgeCheckBox_Changed"/>
                            <TextBlock x:Name="lbl_result"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="#334155"
                                       Text="결과 없음"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <!--Row 5: 피커센터 캘리브레이션 패널 (Bottom 전용 — AV-05)-->
                    <GroupBox Grid.Row="5" Header="피커센터 캘 (36-스텝)" Margin="0,0,0,8">
                        <StackPanel Margin="8">
                            <!--초기화: 누적 스텝 클리어-->
                            <Button x:Name="btn_calReset"
                                    Content="초기화"
                                    Style="{StaticResource BottomActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Click="CalResetButton_Click"/>
                            <!--검색 ROI(원) 지정: Circle 드로잉 시작-->
                            <Button x:Name="btn_calDrawRoi"
                                    Content="검색 ROI(원) 지정"
                                    Style="{StaticResource BottomActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Click="CalDrawRoiButton_Click"/>
                            <!--스텝 추가: Grab + 지그원 검출 → 중심 누적-->
                            <Button x:Name="btn_calAddStep"
                                    Content="스텝 추가 (Grab+검출)"
                                    Style="{StaticResource BottomActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Click="CalAddStepButton_Click"/>
                            <!--피커센터 계산: 누적 지그 중심 → 편심원 피팅-->
                            <Button x:Name="btn_calCompute"
                                    Content="피커센터 계산"
                                    Style="{StaticResource BottomActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Click="CalComputeButton_Click"/>
                            <!--캘 상태: 누적 스텝 수 표시-->
                            <TextBlock x:Name="lbl_calStatus"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="#475569"
                                       Text="누적 0"
                                       TextWrapping="Wrap"/>
                            <!--피커센터 결과: 산출된 row/col/radius 표시-->
                            <TextBlock x:Name="lbl_pickerCenter"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#1E3A8A"
                                       Text=""
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <!--Row 6: 여백-->
                    <Grid Grid.Row="6"/>
                </Grid>
            </ScrollViewer>
        </Border>

        <!--우측 컬럼: 뷰어 호스트 Border (외부 MainWindow 가 AttachSharedViewer 로 자식 주입 — D-03)-->
        <!--airspace-safe: 이 Border 는 좌측 컨트롤 패널과 완전히 분리된 Grid 셀-->
        <Border x:Name="ViewerHostBorder"
                Grid.Column="1"
                Margin="0,12,12,12"
                Background="Black"/>
    </Grid>
</UserControl>
