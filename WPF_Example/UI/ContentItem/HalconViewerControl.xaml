<UserControl x:Class="ReringProject.UI.HalconViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:HalconDotNet;assembly=halcondotnet"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="400">
    <Border x:Name="ViewerBorder"
            BorderBrush="#334155"
            BorderThickness="1"
            Background="#0F172A"
            CornerRadius="6"
            Padding="4">
        <Border.ContextMenu>
            <ContextMenu x:Name="ViewerContextMenu">
                <MenuItem Header="Zoom In" Click="ZoomInMenuItem_Click"/>
                <MenuItem Header="Zoom Out" Click="ZoomOutMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="Fit Image" Click="FitImageMenuItem_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
        <h:HWindowControlWPF x:Name="ViewerHost"/>
    </Border>
</UserControl>

