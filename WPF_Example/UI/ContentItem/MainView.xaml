<UserControl x:Class="ReringProject.UI.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dmv="clr-namespace:ReringProject.UI"
             mc:Ignorable="d" Loaded="MainView_Loaded" d:DesignWidth="1200" d:DesignHeight="800">
    <UserControl.Resources>
        <!-- Phase 2: Shared ToggleButton style for ROI toolbar buttons (D-09, D-10, UI-SPEC toolbar) -->
        <Style x:Key="RoiToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A4A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#FF666666"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- //260408 hbk 툴바 Row 분리 (HWindowControlWPF airspace 문제) -->
            <RowDefinition Height="6*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>

        <!-- Phase 2 Canvas Toolbar — Row 분리 (HWindowControlWPF는 Win32 호스팅이라 ZIndex 오버레이 불가) -->
        <Border x:Name="canvasToolbar" Grid.Row="0" Background="#111827"
                Padding="8,4" Height="36">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ToggleButton x:Name="btn_rectRoi" Content="Rect ROI"
                        Click="RectRoiButton_Click"
                        Style="{StaticResource RoiToggleButtonStyle}"
                        MinWidth="80" Height="28" Padding="12,4"
                        FontSize="13" FontWeight="SemiBold" Margin="0,0,4,0"/>

                    <ToggleButton x:Name="btn_polygonRoi" Content="Polygon ROI"
                        Click="PolygonRoiButton_Click"
                        Style="{StaticResource RoiToggleButtonStyle}"
                        MinWidth="80" Height="28" Padding="12,4"
                        FontSize="13" FontWeight="SemiBold" Margin="0,0,4,0"/>

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="4,4"/>

                    <Button x:Name="btn_calibrate" Content="Calibrate"
                        Click="CalibrateButton_Click"
                        MinWidth="80" Height="28" Padding="12,4"
                        FontSize="13" FontWeight="SemiBold"
                        Background="#2563EB" Foreground="White"
                        BorderBrush="#1D4ED8" BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                <!-- Phase 2: Drawing mode hint + point count (툴바 내 배치) -->
                <Label x:Name="label_drawHint" Grid.Column="1" Visibility="Collapsed"
                       HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       FontSize="13" Foreground="#FFAAAAAA"/>
                <Label x:Name="label_pointCount" Grid.Column="2" Visibility="Collapsed"
                       HorizontalAlignment="Right" VerticalContentAlignment="Center"
                       FontSize="13" Foreground="#FFAAAAAA" Margin="0,0,8,0"/>
            </Grid>
        </Border>

        <!-- Canvas area -->
        <Grid Grid.Row="1" Background="#FF303030">
            <dmv:MainResultViewerControl x:Name="halconViewer"/>
            <Label x:Name="label_message" FontSize="24" Foreground="#FFAAAAAA"
                   Content="NO Image"
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                   IsHitTestVisible="False"/>

            <Border VerticalAlignment="Bottom" Background="#111827" Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label x:Name="label_pos" Grid.Column="1"
                           FontSize="16" Foreground="LightGray"
                           HorizontalContentAlignment="Right" HorizontalAlignment="Right"
                           Content="X:0.0, Y:0.0, G:-"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Horizontal GridSplitter -->
        <GridSplitter Grid.Row="2" Height="5"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="#FF555555"/>

        <!-- DataGrid result table -->
        <DataGrid x:Name="dataGrid_faiResults" Grid.Row="3"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionUnit="FullRow"
                  SelectionChanged="FAIResults_SelectionChanged"
                  Background="#FF1A202C" Foreground="#FFFFFFFF"
                  HeadersVisibility="Column" GridLinesVisibility="None">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF3A3A4A"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="BorderBrush" Value="#FF555555"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="4,2"/>
                </Style>
            </DataGrid.CellStyle>
            <!-- Per D-06/D-11: OK/NG color coding -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#FF2D2D2D"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsPass}" Value="True"/>
                                <Condition Binding="{Binding HasResult}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#FF204020"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsPass}" Value="False"/>
                                <Condition Binding="{Binding HasResult}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#FF402020"/>
                        </MultiDataTrigger>
                        <DataTrigger Binding="{Binding HasResult}" Value="False">
                            <Setter Property="Background" Value="#FF2D2D2D"/>
                            <Setter Property="Foreground" Value="#FF8899AA"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <!--260417 hbk Phase 6 Plan 04: Measurement 단위 컬럼 (FAI/Measurement/Type/DatumRef/공차/측정값/판정)-->
            <DataGrid.Columns>
                <DataGridTextColumn Header="FAI" Binding="{Binding FAIName}" Width="*"/>
                <DataGridTextColumn Header="Measurement" Binding="{Binding MeasurementName}" Width="*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="Auto"/>
                <DataGridTextColumn Header="DatumRef" Binding="{Binding DatumRef}" Width="Auto"/>
                <DataGridTextColumn Header="Nominal" Binding="{Binding NominalValue}" Width="Auto"/>
                <DataGridTextColumn Header="Tol+" Binding="{Binding TolerancePlus}" Width="Auto"/>
                <DataGridTextColumn Header="Tol-" Binding="{Binding ToleranceMinus}" Width="Auto"/>
                <DataGridTextColumn Header="측정값" Binding="{Binding MeasuredValueText}" Width="Auto"/>
                <DataGridTextColumn Header="판정" Binding="{Binding JudgeText}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
