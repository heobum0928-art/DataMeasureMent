<UserControl x:Class="ReringProject.UI.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dmv="clr-namespace:ReringProject.UI"
             xmlns:seq="clr-namespace:ReringProject.Sequence"
             mc:Ignorable="d" Loaded="MainView_Loaded" d:DesignWidth="1200" d:DesignHeight="800">
    <UserControl.Resources>
        <!-- Phase 2: Shared ToggleButton style for ROI toolbar buttons (D-09, D-10, UI-SPEC toolbar) -->
        <Style x:Key="RoiToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A4A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#FF666666"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--260527 hbk Phase 34.1 CO-34.1-04 hotfix — 가로축 토글 전용 스타일 (활성 시 Material Blue 700 #1976D2).
             RoiToggleButtonStyle 의 generic blue (#2563EB) 와 시각적으로 거의 동일해 사용자가 활성 축 구분 어려움 → 축 색상 강제.-->
        <Style x:Key="SwapHorizontalToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource RoiToggleButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1976D2"/> <!--260527 hbk Phase 34.1 D-34.1-14 — 가로축 Blue 700-->
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A4A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#1976D2"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#FF666666"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--260527 hbk Phase 34.1 CO-34.1-04 hotfix — 세로축 토글 전용 스타일 (활성 시 Material Orange 800 #F57C00).-->
        <Style x:Key="SwapVerticalToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource RoiToggleButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F57C00"/> <!--260527 hbk Phase 34.1 D-34.1-14 — 세로축 Orange 800-->
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E65100"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A4A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#F57C00"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#FF666666"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- //260408 hbk 툴바 Row 분리 (HWindowControlWPF airspace 문제) -->
            <RowDefinition Height="6*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>

        <!-- Phase 2 Canvas Toolbar — Row 분리 (HWindowControlWPF는 Win32 호스팅이라 ZIndex 오버레이 불가) -->
        <Border x:Name="canvasToolbar" Grid.Row="0" Background="#111827"
                Padding="8,4" Height="36">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ToggleButton x:Name="btn_rectRoi" Content="Rect ROI"
                        Click="RectRoiButton_Click"
                        Style="{StaticResource RoiToggleButtonStyle}"
                        MinWidth="80" Height="28" Padding="12,4"
                        FontSize="13" FontWeight="SemiBold" Margin="0,0,4,0"/>

                    <!--260601 hbk Phase 40.1 #4 — Polygon ROI 생성 진입점 숨김 (RoiShape.Polygon enum + 렌더 분기 보존, 데이터 호환)-->
                    <ToggleButton x:Name="btn_polygonRoi" Content="Polygon ROI"
                        Click="PolygonRoiButton_Click"
                        Style="{StaticResource RoiToggleButtonStyle}"
                        Visibility="Collapsed"
                        MinWidth="80" Height="28" Padding="12,4"
                        FontSize="13" FontWeight="SemiBold" Margin="0,0,4,0"/>

                    <!--260423 hbk Phase 11 D-15 Circle ROI 드로잉 토글-->
                    <ToggleButton x:Name="btn_circleRoi" Content="Circle ROI"
                        Click="CircleRoiButton_Click"
                        Style="{StaticResource RoiToggleButtonStyle}"
                        IsEnabled="False"
                        MinWidth="80" Height="28" Padding="12,4"
                        FontSize="13" FontWeight="SemiBold" Margin="0,0,4,0"/>

                    <!--260424 hbk Phase 12 D-01 — Datum 티칭 토글 (TwoLineIntersect / CircleTwoHorizontal / VerticalTwoHorizontal 3-way 상태머신 진입)-->
                    <ToggleButton x:Name="btn_teachDatum" Content="Teach Datum"
                        Click="TeachDatumButton_Click"
                        Style="{StaticResource RoiToggleButtonStyle}"
                        IsEnabled="False"
                        MinWidth="100" Height="28" Padding="12,4"
                        FontSize="13" FontWeight="SemiBold" Margin="0,0,4,0"/>

                    <!--260527 hbk Phase 34.1 D-34.1-02/09 — DualImage 변형 수동 swap 토글 (가로축/세로축). Visibility 는 code-behind 의 OnDatumSelectionChanged / AlgorithmTypeChanged 에서 제어.
                         260527 hbk Phase 34.1 CO-34.1-04 hotfix — Style 을 SwapHorizontalToggleStyle 로 교체 (활성 시 #1976D2 Blue 700).-->
                    <ToggleButton x:Name="btn_swapHorizontal" Content="👁 가로"
                        Click="BtnSwapHorizontal_Click"
                        Style="{StaticResource SwapHorizontalToggleStyle}"
                        IsEnabled="True" Visibility="Collapsed"
                        MinWidth="80" Height="28" Padding="12,4"
                        FontSize="13" FontWeight="SemiBold" Margin="0,0,4,0"
                        ToolTip="가로축 이미지로 전환 (HorizontalA + HorizontalB ROI 표시)"/>

                    <!--260527 hbk Phase 34.1 D-34.1-02/09 — DualImage 변형 수동 swap 토글 (세로축).
                         260527 hbk Phase 34.1 CO-34.1-04 hotfix — Style 을 SwapVerticalToggleStyle 로 교체 (활성 시 #F57C00 Orange 800).-->
                    <ToggleButton x:Name="btn_swapVertical" Content="👁 세로"
                        Click="BtnSwapVertical_Click"
                        Style="{StaticResource SwapVerticalToggleStyle}"
                        IsEnabled="True" Visibility="Collapsed"
                        MinWidth="80" Height="28" Padding="12,4"
                        FontSize="13" FontWeight="SemiBold" Margin="0,0,4,0"
                        ToolTip="세로축 이미지로 전환 (Vertical ROI 표시)"/>

                    <!--260424 hbk Phase 13 D-05 — 런타임 TryFindDatum 테스트 버튼 (Datum teach 완료 후 활성화)-->
                    <Button x:Name="btn_testFindDatum" Content="Test Find"
                        Click="BtnTestFindDatum_Click"
                        IsEnabled="True"
                        MinWidth="80" Height="28" Padding="12,4"
                        FontSize="13" FontWeight="SemiBold"
                        Background="#2563EB" Foreground="White"
                        BorderBrush="#1D4ED8" BorderThickness="1"
                        Margin="0,0,4,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="4,4"/>

                    <Button x:Name="btn_calibrate" Content="Calibrate"
                        Click="CalibrateButton_Click"
                        MinWidth="80" Height="28" Padding="12,4"
                        FontSize="13" FontWeight="SemiBold"
                        Background="#2563EB" Foreground="White"
                        BorderBrush="#1D4ED8" BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!--260601 hbk Phase 40.1 #2 — overlay On/Off 토글 (기본 ON). 측정 overlay / Datum 라인 독립.-->
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,4"/>
                    <CheckBox x:Name="chk_overlayMeasure" Content="측정 overlay"
                        IsChecked="True"
                        Checked="Chk_overlayMeasure_Changed" Unchecked="Chk_overlayMeasure_Changed"
                        Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <CheckBox x:Name="chk_overlayDatum" Content="Datum 라인"
                        IsChecked="True"
                        Checked="Chk_overlayDatum_Changed" Unchecked="Chk_overlayDatum_Changed"
                        Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                </StackPanel>
                <!-- Phase 2: Drawing mode hint + point count (툴바 내 배치) -->
                <Label x:Name="label_drawHint" Grid.Column="1" Visibility="Collapsed"
                       HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       FontSize="13" Foreground="#FFAAAAAA"/>
                <!--260503 hbk Phase 17 D-15 — label_pointCount 보존 (Polygon 모드 code-behind 5 사이트 참조 — Rule 3 회귀 방지). 기본 Collapsed.-->
                <Label x:Name="label_pointCount" Grid.Column="2" Visibility="Collapsed"
                       HorizontalAlignment="Right" VerticalContentAlignment="Center"
                       FontSize="13" Foreground="#FFAAAAAA" Margin="0,0,8,0"/>
                <!--260503 hbk Phase 17 D-15 — Hover 좌표 + 밝기 (X / Y / Gray). Column 2 공유 — label_pointCount 가 Collapsed 일 때만 가시 (Polygon 모드 진입 시 자동 숨김 처리는 별도 wiring 불필요 — label_pointCount Visible 시 같은 Column 영역 우선).-->
                <StackPanel x:Name="panel_hoverInfo" Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock x:Name="txt_hoverX" Text="X: N/A" FontSize="13" Foreground="#FFAAAAAA"
                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="·" FontSize="13" Foreground="#FFAAAAAA"
                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txt_hoverY" Text="Y: N/A" FontSize="13" Foreground="#FFAAAAAA"
                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="·" FontSize="13" Foreground="#FFAAAAAA"
                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txt_hoverG" Text="Gray: N/A" FontSize="13" Foreground="#FFAAAAAA"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!--260424 hbk Phase 13 D-07 — 런타임 TryFindDatum 결과 label (성공 LimeGreen / 실패 Red)-->
                <Label x:Name="label_testFindResult" Grid.Column="1" Visibility="Collapsed"
                       HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       FontSize="13" Foreground="#FFAAAAAA"/>
            </Grid>
        </Border>

        <!-- Canvas area -->
        <Grid Grid.Row="1" Background="#FF303030">
            <dmv:MainResultViewerControl x:Name="halconViewer"/>
            <Label x:Name="label_message" FontSize="24" Foreground="#FFAAAAAA"
                   Content="NO Image"
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                   IsHitTestVisible="False"/>

            <!--260527 hbk Phase 34.1 D-34.1-03/14 — 현재 표시 이미지 배지 (캔버스 우상단, DualImage 변형일 때만 Visible).
                 색상/텍스트는 code-behind UpdateImageSourceBadge(EImageSource) 에서 setting.
                 가로축 = #1976D2 Material Blue 700 / 세로축 = #F57C00 Material Orange 800 / 14px / 마진 우상단 12px.-->
            <Border x:Name="border_imageSourceBadge"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,12,12,0" Padding="10,4"
                    CornerRadius="4" Background="#1976D2"
                    Visibility="Collapsed" IsHitTestVisible="False">
                <TextBlock x:Name="txt_imageSourceBadge"
                           Text="가로축" Foreground="White"
                           FontSize="14" FontWeight="SemiBold"/>
            </Border>

            <!--260528 hbk Phase 36 D-36-06 — DualImage 검출 각도 PASS/FAIL 색상 배지 (PropertyGrid 외부 별도 라벨, 캔버스 우상단).
                 가드 4파일 변경 0 정합. D-36-06 갱신 (2026-05-28) — 옵션 C (외부 Border) 채택.
                 AngleValidationStatus transient 필드 바인딩 → Trigger 로 색상/텍스트 분기. None=숨김 / Pass=green "검증 OK" / Fail=red "검증 NG".
                 DataContext = 현재 선택된 DatumConfig (halconViewer 또는 InspectionListView SelectedItem chain). -->
            <Border x:Name="border_angleValidationBadge"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,52,12,0"
                    Padding="10,4"
                    CornerRadius="4"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <!--260528 hbk Phase 36 D-36-06 — Pass: 연두 배경 + "각도 검증 OK"-->
                            <DataTrigger Binding="{Binding AngleValidationStatus}" Value="{x:Static seq:EAngleValidationStatus.Pass}">
                                <Setter Property="Background" Value="#43A047"/>
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!--260528 hbk Phase 36 D-36-06 — Fail: 연빨 배경 + "각도 검증 NG"-->
                            <DataTrigger Binding="{Binding AngleValidationStatus}" Value="{x:Static seq:EAngleValidationStatus.Fail}">
                                <Setter Property="Background" Value="#E53935"/>
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!--None 또는 unset: Visibility Collapsed (default)-->
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="14">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AngleValidationStatus}" Value="{x:Static seq:EAngleValidationStatus.Pass}">
                                    <Setter Property="Text" Value="각도 검증 OK"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AngleValidationStatus}" Value="{x:Static seq:EAngleValidationStatus.Fail}">
                                    <Setter Property="Text" Value="각도 검증 NG"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <Border VerticalAlignment="Bottom" Background="#111827" Padding="12,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!--260519 hbk Phase 31 CO-23.1-01 — 이미지 출처 레이블 행 추가-->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!--260425 hbk Phase 13 D-VIZ-06 — Datum reference 좌표 텍스트 라벨 (Datum 노드 선택/티칭 성공/ROI 이동 시 갱신)-->
                    <Label x:Name="label_datumRefCoords" Grid.Row="0" Grid.Column="0" Visibility="Collapsed"
                           FontSize="13" Foreground="#FFCBD5E0"
                           HorizontalContentAlignment="Left" HorizontalAlignment="Left"
                           VerticalContentAlignment="Center"/>
                    <Label x:Name="label_pos" Grid.Row="0" Grid.Column="1"
                           FontSize="16" Foreground="LightGray"
                           HorizontalContentAlignment="Right" HorizontalAlignment="Right"
                           Content="X:0.0, Y:0.0, G:-"/>
                    <!--260519 hbk Phase 31 CO-23.1-01 — 이미지 출처 레이블 (티칭/검사 이미지 경로 표시)-->
                    <TextBlock x:Name="txt_imageSourceLabel" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                               Visibility="Collapsed"
                               FontSize="11" Foreground="#FF88A0C0"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" Margin="0,2,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Horizontal GridSplitter -->
        <GridSplitter Grid.Row="2" Height="5"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="#FF555555"/>

        <!-- DataGrid result table -->
        <DataGrid x:Name="dataGrid_faiResults" Grid.Row="3"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionUnit="FullRow"
                  SelectionChanged="FAIResults_SelectionChanged"
                  Background="#FF1A202C" Foreground="#FFFFFFFF"
                  HeadersVisibility="Column" GridLinesVisibility="None">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF3A3A4A"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="BorderBrush" Value="#FF555555"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="4,2"/>
                </Style>
            </DataGrid.CellStyle>
            <!-- Per D-06/D-11: OK/NG color coding -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#FF2D2D2D"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsPass}" Value="True"/>
                                <Condition Binding="{Binding HasResult}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#FF204020"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsPass}" Value="False"/>
                                <Condition Binding="{Binding HasResult}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#FF402020"/>
                        </MultiDataTrigger>
                        <DataTrigger Binding="{Binding HasResult}" Value="False">
                            <Setter Property="Background" Value="#FF2D2D2D"/>
                            <Setter Property="Foreground" Value="#FF8899AA"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <!--260417 hbk Phase 6 Plan 04: Measurement 단위 컬럼 (FAI/Measurement/Type/DatumRef/공차/측정값/판정)-->
            <DataGrid.Columns>
                <DataGridTextColumn Header="FAI" Binding="{Binding FAIName}" Width="*"/>
                <DataGridTextColumn Header="Measurement" Binding="{Binding MeasurementName}" Width="*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="Auto"/>
                <DataGridTextColumn Header="DatumRef" Binding="{Binding DatumRef}" Width="Auto"/>
                <DataGridTextColumn Header="Nominal" Binding="{Binding NominalValue}" Width="Auto"/>
                <DataGridTextColumn Header="Tol+" Binding="{Binding TolerancePlus}" Width="Auto"/>
                <DataGridTextColumn Header="Tol-" Binding="{Binding ToleranceMinus}" Width="Auto"/>
                <DataGridTextColumn Header="측정값" Binding="{Binding MeasuredValueText}" Width="Auto"/>
                <DataGridTextColumn Header="판정" Binding="{Binding JudgeText}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
