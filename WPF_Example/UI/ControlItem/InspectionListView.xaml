<UserControl x:Class="ReringProject.UI.InspectionListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             xmlns:local="clr-namespace:ReringProject.UI"
             xmlns:propToolsWpf="clr-namespace:PropertyTools.Wpf;assembly=PropertyTools.Wpf"
             xmlns:propTools="clr-namespace:PropertyTools;assembly=PropertyTools"
             
             d:DesignHeight="800" d:DesignWidth="400" MinWidth="200" Loaded="ListView_Loaded">
    <UserControl.Resources>
        <!-- 260530 hbk Phase 39.2 D-G4 — Tree 노드 아이콘 Geometry resources + converter -->
        <local:IconKeyToGeometryConverter x:Key="iconKeyToGeometry"/>

        <!-- 5 NodeType -->
        <Geometry x:Key="Geometry.Icon.Recipe">M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Sequence">M5,4H7V8H9V4H11V14H9V10H7V14H5V4M13,4H15V8H17V4H19V14H17V10H15V14H13V4M5,16H19V18H5V16M5,20H19V22H5V20Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Action">M12,16L19.36,10.27L21,9L12,2L3,9L4.63,10.27L12,16M12,18.54L4.62,12.81L3,14.07L12,21.07L21,14.07L19.37,12.81L12,18.54Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Datum">M11,2V4.07C7.38,4.53 4.53,7.38 4.07,11H2V13H4.07C4.53,16.62 7.38,19.47 11,19.93V22H13V19.93C16.62,19.47 19.47,16.62 19.93,13H22V11H19.93C19.47,7.38 16.62,4.53 13,4.07V2M11,6.08V8H13V6.09C15.5,6.5 17.5,8.5 17.92,11H16V13H17.91C17.5,15.5 15.5,17.5 13,17.92V16H11V17.91C8.5,17.5 6.5,15.5 6.08,13H8V11H6.09C6.5,8.5 8.5,6.5 11,6.08M12,11A1,1 0 0,0 11,12A1,1 0 0,0 12,13A1,1 0 0,0 13,12A1,1 0 0,0 12,11Z</Geometry>
        <Geometry x:Key="Geometry.Icon.FAI">M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M9,17H7V10H9V17M13,17H11V7H13V17M17,17H15V13H17V17Z</Geometry>

        <!-- Measurement fallback (TypeName 매칭 실패 시 또는 ParamData 미상) -->
        <Geometry x:Key="Geometry.Icon.Measurement">M3,3H21V21H3V3M5,5V19H19V5H5Z</Geometry>

        <!-- 12 Measurement TypeName -->
        <Geometry x:Key="Geometry.Icon.Meas.CircleDiameter">M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M3,12L21,12Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Meas.EdgeToLineDistance">M4,18H20V20H4V18M12,2L5,12H9V16H15V12H19L12,2Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Meas.PointToLineDistance">M12,7A2,2 0 1,0 12,11A2,2 0 0,0 12,7M4,18H20V20H4V18M12,14L8,18H16L12,14Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Meas.EdgePairDistance">M4,4H20V6H4V4M4,18H20V20H4V18M4,11H20V13H4V11Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Meas.EdgeToLineAngle">M21,21H3L21,3V21M5.83,19H19V5.83L5.83,19Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Meas.ArcEdgeDistance">M2,17H22V19H2V17M12,3A6,6 0 0,1 18,9A6,6 0 0,1 12,15A6,6 0 0,1 6,9A6,6 0 0,1 12,3M12,5A4,4 0 0,0 8,9A4,4 0 0,0 12,13A4,4 0 0,0 16,9A4,4 0 0,0 12,5Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Meas.ArcLineIntersectDistance">M3,11L21,11V13L3,13V11M12,3A8,8 0 0,1 20,11H18A6,6 0 0,0 12,5A6,6 0 0,0 6,11H4A8,8 0 0,1 12,3Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Meas.CompoundAngle">M21,21H3L21,3V21M5.83,19H19V5.83L5.83,19M14,17L17,14L17,17L14,17Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Meas.CompoundCenterCDistance">M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M22,12L18,8V11H14V13H18V16L22,12Z</Geometry>
        <!-- W1 fix: CompoundCenterBDistance — 중복 segment 제거, 좌측 화살표 mirror 정상화 (CompoundCenterCDistance 와 좌우 대칭) -->
        <Geometry x:Key="Geometry.Icon.Meas.CompoundCenterBDistance">M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M2,12L6,16V13H10V11H6V8L2,12Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Meas.CompoundShortAxisDistance">M2,12L6,8V11H10V13H6V16L2,12M22,12L18,16V13H14V11H18V8L22,12Z</Geometry>
        <Geometry x:Key="Geometry.Icon.Meas.DualImageEdgeDistance">M3,3H10V10H3V3M14,3H21V10H14V3M3,14H10V21H3V14M14,14H21V21H14V14M11,12L13,12L13,11L11,11L11,12Z</Geometry>

        <!-- Default fallback -->
        <Geometry x:Key="Geometry.Icon.Default">M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z</Geometry>

        <Style TargetType="Button" x:Key="disalbedStyle">
            <Setter Property="Background" Value="Transparent"></Setter>
            <Setter Property="BorderThickness" Value="0"></Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter x:Name="MyContentPresenter" 
                                        Content="{TemplateBinding Content}"
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"></Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Opacity" Value="1"></Setter>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="LightSkyBlue"></Setter>
                    <Setter Property="BorderThickness" Value="1"></Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- 260530 hbk Phase 39.2 D-G4 — NodeType + Measurement TypeName 별 Geometry icon (was Image / ImageSource PNG) -->
        <DataTemplate DataType="{x:Type local:NodeViewModel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- 260530 hbk Phase 39.2 D-G4: Image PNG → Path Geometry (Material Icons inline path data). Fill = TextElement foreground (theme 호환). -->
                <Path Grid.Column="0" Width="24" Height="24" Margin="0 0 4 0"
                      Stretch="Uniform"
                      Fill="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource Self}}"
                      Data="{Binding IconKey, Converter={StaticResource iconKeyToGeometry}}"/>
                <propToolsWpf:EditableTextBlock Grid.Column="1" Text="{Binding Name}" IsEditing="{Binding IsEditing}"/>
            </Grid>
        </DataTemplate>
        <!-- property grid customize-->
        <!-- Category Header -->
        <DataTemplate x:Key="HeaderTemplate1">
            <StackPanel Orientation="Horizontal">
                <propToolsWpf:Bitmap Source="/Resource/home.png"/>
                <TextBlock Text="{Binding}" FontSize="14" FontWeight="Bold" Margin="4,0,0,0"/>
            </StackPanel>
        </DataTemplate>
        <!-- Unused : TabPageHeader -->
        <DataTemplate x:Key="PageHeaderTemplate1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding }" FontSize="18" FontWeight="Bold" Margin="0 0 8 0"/>
                <propToolsWpf:Bitmap Source="/Resource/home.png" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
        <!-- Error Style-->
        <Style x:Key="TabHeaderErrorsStyle">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasWarnings}" Value="True">
                    <Setter Property="TextBlock.Foreground" Value="Orange"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasErrors}" Value="True">
                    <Setter Property="TextBlock.Foreground" Value="Red"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Tab Header -->
        <DataTemplate x:Key="HeaderTemplate2" DataType="propTools:Tab">
            <StackPanel Orientation="Horizontal">
                <propToolsWpf:Bitmap Source="/Resource/chart.png" Margin="0 0 4 0"/>
                <TextBlock Text="{Binding Header}" Margin="4 0 0 0" Style="{StaticResource TabHeaderErrorsStyle}"/>
            </StackPanel>
        </DataTemplate>
        <!-- CategoryControl -->
        <ControlTemplate x:Key="CategoryControlTemplate1"  TargetType="{x:Type HeaderedContentControl}">
            <Grid Margin="0 8 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                <Separator Grid.Column="1" Margin="4 3 0 0"/>
                <ContentPresenter Grid.Row="1" Grid.ColumnSpan="2"/>
            </Grid>
        </ControlTemplate>
        <!-- control Context menu -->
        <ContextMenu x:Key="menu_control" FontSize="18">
            <MenuItem Header="Save" Height="36" MinHeight="36" Click="MenuItem_Save_Click">
                <MenuItem.Icon>
                    <Image Source="/Resource/save.png"></Image>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Save As" Height="36" MinHeight="36" Click="MenuItem_Save_As_Click">
                <MenuItem.Icon>
                    <Image Source="/Resource/saveas.png"></Image>
                </MenuItem.Icon>
            </MenuItem>
            <Separator></Separator>
            <MenuItem Header="Open Recipe" Height="36" MinHeight="36" Click="MenuItem_open_Click">
                <MenuItem.Icon>
                    <Image Source="/Resource/folder.png"></Image>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
        
        <!-- Edit Context menu -->
        <ContextMenu x:Key="menu_customConfig" FontSize="18">
        </ContextMenu>

    </UserControl.Resources>
    <Border BorderThickness="1" BorderBrush="Gray">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"></ColumnDefinition>
                <ColumnDefinition Width="5"></ColumnDefinition>
                <ColumnDefinition x:Name="colDefinition_editor" Width="6*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"></RowDefinition>
                <RowDefinition Height="60*"></RowDefinition>
                <RowDefinition Height="5"></RowDefinition>
            </Grid.RowDefinitions>

            <!-- Recipe Name -->
            <Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"></ColumnDefinition>
                    <ColumnDefinition Width="3*"></ColumnDefinition>
                    <ColumnDefinition Width="2*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <TextBox x:Name="tb_RecipeName" Grid.Column="0" Grid.Row="0" Margin="0,2,2,2" FontSize="19" IsReadOnly="True" Text="{Binding CurrentRecipe}"></TextBox>

                <Button x:Name="btn_start" Grid.Column="1" Grid.Row="0" Margin="0,2,0,2" FontSize="18" Click="Btn_start_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Image Source="/resource/process.png"></Image>
                        <TextBlock Text="RUN"></TextBlock>
                    </StackPanel>
                </Button>
                <Button x:Name="btn_RecipeSelect" Grid.Column="2" Grid.Row="0" Margin="2,2,2,2" FontSize="18" Content="..." ContextMenu="{StaticResource menu_control}" Click="Btn_RecipeSelect_Click">
                </Button>
            </Grid>
            
            
            <!-- Inspection Group List -->
            <propToolsWpf:TreeListBox x:Name="treeListBox_sequence" Grid.Column="0" Grid.Row="1" Margin="0,2,0,0" BorderThickness="1" BorderBrush="Gray" HierarchySource="{Binding Root}" Indentation="12" AllowDrop="False" ScrollViewer.IsDeferredScrollingEnabled="True"
                                      SelectionChanged="InspectionList_SelectionChanged">
            </propToolsWpf:TreeListBox>
            
            <!-- Splitter -->
            <GridSplitter x:Name="gridSplitter_editor" Width="5" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Stretch" ShowsPreview="True" BorderThickness="1" BorderBrush="Gray"></GridSplitter>

            <!-- Inspection Editor -->
            <Grid x:Name="grid_editor" Grid.Column="2" Grid.Row="1" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"></ColumnDefinition>
                    <ColumnDefinition Width="10*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10*"></RowDefinition>
                </Grid.RowDefinitions>

                <ToolBarTray x:Name="toolbar_tray" Grid.Column="0" Grid.Row="0" IsLocked="True" Orientation="Vertical">
                    <ToolBar>
                        <Button x:Name="button_grab" Click="button_grab_Click" IsEnabled="False"  Style="{StaticResource disalbedStyle}">
                            <StackPanel Orientation="Vertical" >
                                <Image Source="/Resource/camera.png" Stretch="Uniform" Width="42" Height="42"></Image>
                                <TextBlock Text="Grab" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                            </StackPanel>
                        </Button>
                        <Button x:Name="button_loadImage" Click="button_loadImage_Click" IsEnabled="False" Style="{StaticResource disalbedStyle}">
                            <StackPanel Orientation="Vertical">
                                <Image Source="/Resource/folder.png" Stretch="Uniform" Width="42" Height="42"></Image>
                                <TextBlock Text="Load" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                            </StackPanel>
                        </Button>
                        <Button x:Name="button_light" Click="button_light_Click" IsEnabled="False"  Style="{StaticResource disalbedStyle}">
                            <StackPanel Orientation="Vertical" >
                                <Image Source="/Resource/light.png" Stretch="Uniform" Width="42" Height="42"></Image>
                                <TextBlock Text="Light" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                            </StackPanel>
                        </Button>
                        <Separator></Separator>
                    </ToolBar>
                    <!--
                    <ToolBar>
                        <Button x:Name="button_showConfig" IsEnabled="False" Click="Button_showConfig_Click" Style="{StaticResource disalbedStyle}">
                            <StackPanel Orientation="Vertical">
                                <Image Source="/Resource/dialog.png" Stretch="Uniform" Width="42" Height="42"></Image>
                                <TextBlock Text="Model" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                            </StackPanel>
                        </Button>
                        <Separator></Separator>
                    </ToolBar>
                    -->
                    <ToolBar>
                        <Button x:Name="button_copy" Click="button_copy_Click"  Style="{StaticResource disalbedStyle}">
                            <StackPanel Orientation="Vertical">
                                <Image Source="/Resource/copy.png" Stretch="Uniform" Width="42" Height="42"></Image>
                                <TextBlock Text="Copy" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                            </StackPanel>
                        </Button>

                        <Button x:Name="button_paste" Click="button_paste_Click" IsEnabled="False"  Style="{StaticResource disalbedStyle}">
                            <StackPanel Orientation="Vertical">
                                <Image Source="/Resource/paste.png" Stretch="Uniform" Width="42" Height="42"></Image>
                                <TextBlock Text="paste" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                            </StackPanel>
                        </Button>
                    </ToolBar>
                    <ToolBar>
                        <Button x:Name="button_addFAI" Click="Btn_AddFAI_Click" IsEnabled="False" Style="{StaticResource disalbedStyle}">
                            <StackPanel Orientation="Vertical">
                                <Image Source="/Resource/layout.png" Stretch="Uniform" Width="42" Height="42"/>
                                <TextBlock Text="Add" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="button_removeFAI" Click="Btn_RemoveFAI_Click" IsEnabled="False" Style="{StaticResource disalbedStyle}">
                            <StackPanel Orientation="Vertical">
                                <Image Source="/Resource/layout.png" Stretch="Uniform" Width="42" Height="42"/>
                                <TextBlock Text="Del" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="button_renameFAI" Click="Btn_RenameFAI_Click" IsEnabled="False" Style="{StaticResource disalbedStyle}">
                            <StackPanel Orientation="Vertical">
                                <Image Source="/Resource/layout.png" Stretch="Uniform" Width="42" Height="42"/>
                                <TextBlock Text="Edit" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </ToolBar>
                </ToolBarTray>

                <propToolsWpf:PropertyGrid x:Name="ParamEditor" Grid.Column="1" Grid.Row="0" Margin="0" BorderThickness="0" BorderBrush="Gray" 
                                        CategoryControlTemplate="{StaticResource CategoryControlTemplate1}"
                                        CategoryHeaderTemplate="{StaticResource HeaderTemplate1}"
                                        TabHeaderTemplate="{StaticResource HeaderTemplate2}"
                                        DescriptionIcon="/Resource/lightbulb.png"
                                        SelectedObject="{Binding SelectedItem.Param, ElementName=treeListBox_sequence}">
                </propToolsWpf:PropertyGrid>
            </Grid>

        </Grid>
    </Border>
</UserControl>
