<Window x:Class="ReringProject.UI.CalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewers="clr-namespace:ReringProject.UI"
        mc:Ignorable="d"
        Title="픽셀 캘리브레이션 (체커보드)"
        Height="860"
        Width="1400"
        WindowStartupLocation="CenterOwner">
    <!--260623 hbk Phase 53: 체커보드 픽셀 캘리브 창 (TeachingWindow 패턴 차용)-->
    <Window.Resources>
        <Style x:Key="CalibrationActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E3A8A"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#172554"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#CBD5E1"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#CBD5E1"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#E2E8F0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Margin="12" Padding="12" Background="#F8FAFC" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="픽셀 캘리브레이션"/>
                    <TextBlock Margin="0,4,0,0" Foreground="#475569" Text="체커보드 코너 검출 → mm/px 산출"/>
                </StackPanel>
                <GroupBox Grid.Row="1" Header="칸 크기" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="격자 한 칸 실제 크기 (mm)"/>
                        <TextBox x:Name="txt_cellMm" Margin="0,4,0,0" Text="1.0"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox Grid.Row="2" Header="검출 튜닝" Margin="0,0,0,8">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="saddle Sigma" Margin="0,0,8,4" VerticalAlignment="Center"/>
                        <TextBox x:Name="txt_sigma" Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="saddle Threshold" Margin="0,0,8,4" VerticalAlignment="Center"/>
                        <TextBox x:Name="txt_threshold" Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="왜곡 임계 (%)" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBox x:Name="txt_warnPct" Grid.Row="2" Grid.Column="1"/>
                    </Grid>
                </GroupBox>
                <WrapPanel Grid.Row="3" Margin="0,0,0,8">
                    <Button x:Name="btn_loadImage" Style="{StaticResource CalibrationActionButtonStyle}" Content="이미지 로드" Click="LoadImageButton_Click"/>
                    <Button x:Name="btn_liveCapture" Style="{StaticResource CalibrationActionButtonStyle}" Content="라이브 촬상" Click="GrabImageButton_Click"/>
                    <Button x:Name="btn_detect" Style="{StaticResource CalibrationActionButtonStyle}" Content="검출" Click="DetectButton_Click"/>
                    <Button x:Name="btn_apply" Style="{StaticResource CalibrationActionButtonStyle}" Content="적용" Click="ApplyButton_Click" IsEnabled="False"/>
                </WrapPanel>
                <GroupBox Grid.Row="4" Header="산출 리포트" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock x:Name="txt_report" TextWrapping="Wrap" Foreground="#334155" Text="검출 결과가 여기에 표시됩니다."/>
                        <TextBlock x:Name="lbl_distortionWarn" Margin="0,8,0,0" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="Red" Visibility="Collapsed"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Border>
        <Grid Grid.Column="1" Margin="0,12,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <viewers:HalconViewerControl x:Name="CalibrationViewer"/>
            <StatusBar Grid.Row="1" Margin="0,8,0,0">
                <StatusBarItem>
                    <TextBlock x:Name="CalibrationStatusTextBlock" Text="Ready"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Grid>
</Window>
