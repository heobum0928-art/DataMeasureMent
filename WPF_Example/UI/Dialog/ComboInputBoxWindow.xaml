<Window x:Class="ReringProject.UI.ComboInputBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReringProject.UI"
        mc:Ignorable="d"
        Title="ComboInputBox" Height="180" Width="400" WindowStyle="None" WindowStartupLocation="CenterOwner" IsVisibleChanged="Window_IsVisibleChanged">
    <!--260508 hbk Quick: 측정 타입 등 옵션이 정해진 자유 텍스트 입력 다이얼로그(TextInputBox 패턴)를 콤보박스 다이얼로그로 교체-->
    <Border BorderThickness="5" BorderBrush="SkyBlue">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"></RowDefinition>
                <RowDefinition Height="2*"></RowDefinition>
                <RowDefinition Height="2*"></RowDefinition>
            </Grid.RowDefinitions>
            <Label x:Name="label_title" Grid.Column="0" Grid.Row="0" FontSize="18" VerticalContentAlignment="Bottom">Please Select :</Label>
            <ComboBox x:Name="combo_items" Grid.Column="0" Grid.Row="1" Margin="5" FontSize="22" KeyUp="Combo_items_KeyUp"></ComboBox>
            <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                <Button x:Name="button_cancel" MinWidth="100" FontSize="22" Margin="0,0,4,0" Click="Button_cancel_Click">Cancel</Button>
                <Button x:Name="button_ok" MinWidth="100" FontSize="22" Click="Button_ok_Click">Ok</Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
