<Window x:Class="ReringProject.UI.TextInputBoxWinidow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReringProject.UI"
        mc:Ignorable="d"
        Title="TextInputBox" Height="220" Width="420" WindowStyle="None" WindowStartupLocation="CenterOwner" IsVisibleChanged="Window_IsVisibleChanged">
    <Border BorderThickness="5" BorderBrush="SkyBlue">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"></RowDefinition>
                <RowDefinition Height="2*"></RowDefinition>
                <RowDefinition Height="2*"></RowDefinition>
            </Grid.RowDefinitions>
            <!-- 260702 hbk: 메세지박스 내용 잘림 버그 수정 — Label 은 TextWrapping 미지원 + 고정 400px 폭이라
                 두 줄짜리 안내문(캘리브레이션 픽셀 거리 등)이 창 밖으로 넘쳐 잘려 보였다. TextBlock+Wrap 으로 교체. -->
            <TextBlock x:Name="label_title" Grid.Column="0" Grid.Row="0" FontSize="18" Margin="5,0"
                       TextWrapping="Wrap" VerticalAlignment="Bottom">Please Input Text :</TextBlock>
            <TextBox x:Name="textBox_text" Grid.Column="0" Grid.Row="1" Margin="5" FontSize="22" KeyUp="TextBox_text_KeyUp"></TextBox>
            <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                <Button x:Name="button_cancel" MinWidth="100" FontSize="22" Margin="0,0,4,0" Click="Button_cancel_Click">Cancel</Button>
                <Button x:Name="button_ok" MinWidth="100" FontSize="22" Click="Button_ok_Click">Ok</Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
