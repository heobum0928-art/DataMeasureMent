<Window x:Class="ReringProject.UI.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="양산 이력 통계 분석" Height="820" Width="1280"
        WindowStartupLocation="CenterOwner">
    <!--260707 hbk STAT-01 D-08/D-09 — 통계분석 비모달 별도 Window (ReviewerWindow 미러)-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="340"/>
        </Grid.RowDefinitions>

        <!-- Row0: 필터바 - 기간 DatePicker(기본 오늘, D-10) + 레시피 콤보 + 조회 버튼 (D-11) -->
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="0,0,0,1" Background="#F0F4F8" Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="기간" VerticalAlignment="Center" FontSize="13" Foreground="#334155" Margin="0,0,6,0"/>
                <DatePicker x:Name="dp_From" Width="130" VerticalAlignment="Center"/>
                <TextBlock Text="~" VerticalAlignment="Center" FontSize="13" Foreground="#334155" Margin="6,0,6,0"/>
                <DatePicker x:Name="dp_To" Width="130" VerticalAlignment="Center"/>
                <TextBlock Text="레시피" VerticalAlignment="Center" FontSize="13" Foreground="#334155" Margin="16,0,6,0"/>
                <ComboBox x:Name="combo_Recipe" Width="180" VerticalAlignment="Center"/>
                <Button x:Name="btn_Query" Content="조회" Click="Btn_Query_Click"
                        Padding="14,4" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Row1: 통계 테이블 (D-06) -->
        <DataGrid x:Name="grid_Stats" Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  SelectionChanged="Grid_Stats_SelectionChanged"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  Margin="4">
            <!--260707 hbk STAT-01 — NG 존재 행 강조(선택 사항, ReviewerWindow RowStyle 패턴 참고)-->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="BorderBrush" Value="#1565C0"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Shot"     Binding="{Binding ShotName}"        Width="70"/>
                <DataGridTextColumn Header="FAI"      Binding="{Binding FAIName}"         Width="70"/>
                <DataGridTextColumn Header="측정명"   Binding="{Binding MeasurementName}" Width="110"/>
                <DataGridTextColumn Header="N"        Binding="{Binding N}"               Width="50"/>
                <DataGridTextColumn Header="평균"     Binding="{Binding Mean, StringFormat=F4}"   Width="75"/>
                <DataGridTextColumn Header="표준편차" Binding="{Binding StdDev, StringFormat=F4}" Width="80"/>
                <DataGridTextColumn Header="범위"     Binding="{Binding Range, StringFormat=F4}"  Width="75"/>
                <DataGridTextColumn Header="Cpk"      Binding="{Binding CpkText}"         Width="65"/>
                <DataGridTextColumn Header="OK"       Binding="{Binding OkCount}"         Width="50"/>
                <DataGridTextColumn Header="NG"       Binding="{Binding NgCount}"         Width="50"/>
                <DataGridTextColumn Header="검출실패" Binding="{Binding DetectFailCount}" Width="65"/>
                <DataGridTextColumn Header="수율"     Binding="{Binding YieldRateText}"   Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row2: 히스토그램(D-14) + 추이(D-13) 차트 2분할 -->
        <Grid Grid.Row="2" Margin="4,0,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="분포 히스토그램 (USL/LSL 표시)"
                       FontSize="12" Foreground="Gray" Margin="4,2"/>
            <!--260707 hbk quick-260707-fdx ChartDirector(유료·워터마크) 제거 → WPF Canvas 직접 렌더-->
            <Border Grid.Row="1" Grid.Column="0" BorderBrush="#CBD5E1" BorderThickness="1" Background="White" Margin="4">
                <Canvas x:Name="canvas_Histogram" ClipToBounds="True" SizeChanged="Canvas_SizeChanged"/>
            </Border>

            <TextBlock Grid.Row="0" Grid.Column="1" Text="측정값 추이 (평균/USL/LSL 표시)"
                       FontSize="12" Foreground="Gray" Margin="4,2"/>
            <Border Grid.Row="1" Grid.Column="1" BorderBrush="#CBD5E1" BorderThickness="1" Background="White" Margin="4">
                <Canvas x:Name="canvas_Trend" ClipToBounds="True" SizeChanged="Canvas_SizeChanged"/>
            </Border>
        </Grid>
    </Grid>
</Window>
